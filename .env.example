# =============================================================================
# SMVShows Stremio Addon - Go Refactor Configuration Environment Template
# =============================================================================

# Server Port
PORT=3000

# Logging Level (options: debug, info, warn, error, fatal)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# SCRAPING & CRAWLING CONFIGURATION
# -----------------------------------------------------------------------------

# Comma-separated forum URLs for various categories (all optional, but need at least one)
SERIES_FORUM_URLS=https://www.tamilmv.cz/index.php?/forums/forum/42-tamil-web-series/
MOVIE_FORUM_URLS=https://www.tamilmv.cz/index.php?/forums/forum/11-tamil-new-movies/
DUBBED_MOVIE_FORUM_URLS=https://www.tamilmv.cz/index.php?/forums/forum/35-tamil-dubbed-movies/

# Crawling pagination boundaries
SCRAPE_START_PAGE=1
SCRAPE_END_PAGE=20

# Scraping concurrency limits (prevent target site rate limiting)
SCRAPER_CONCURRENCY=5
SCRAPER_RETRY_COUNT=3
SCRAPER_TIMEOUT_SECS=30

# Web Scraper User Agent spoofing (emulate modern real browser layout)
SCRAPER_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36"

# Forum sorting query parameters to attach to pagination URLs (optional)
FORUM_SORT_QUERY="&sortby=start_date&sortdirection=desc"

# -----------------------------------------------------------------------------
# DEBRID SERVICES CONFIGURATION
# -----------------------------------------------------------------------------

# Debrid Provider selection (options: realdebrid, torbox, none)
# If omitted or blank, auto-detection chooses the provider based on available API keys.
DEBRID_SERVICE=realdebrid

# Real-Debrid API Authorization Key
REALDEBRID_API_KEY=your_realdebrid_api_token_here

# TorBox Bearer API Key
TORBOX_API_KEY=your_torbox_api_token_here

# -----------------------------------------------------------------------------
# EXTERNAL INTEGRATIONS CONFIGURATION
# -----------------------------------------------------------------------------

# TMDB API v3 Key (required for title resolution and rich metadata lookup)
TMDB_API_KEY=your_tmdb_api_key_here

# Proxy URLs (comma-separated, optional proxy rotation for bypassing cloudflare/limits)
PROXY_URLS=http://username:password@proxy1.example.com:8080,http://username:password@proxy2.example.com:8080

# Trackers source URL (refreshed hourly to seed direct P2P streams)
TRACKER_URL=https://ngosang.github.io/trackerslist/trackers_best.txt

# Base address of the deployed Go addon (used for debrid redirects back to Stremio)
APP_HOST=http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# DATABASE MAINTENANCE & SCHEDULER CONFIGURATION
# -----------------------------------------------------------------------------

# Cron schedule to trigger the background crawling workflow (defaults to every 6 hours)
MAIN_WORKFLOW_CRON="0 */6 * * *"

# Optional weekly sqlite DB vaccum and WAL truncation maintenance
DB_AUTO_VACUUM_ENABLED=true
DB_AUTO_VACUUM_CRON="0 0 * * 0"
