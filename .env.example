# ==========================================
# Server Configuration
# ==========================================
PORT=3000
LOG_LEVEL=info
APP_HOST=http://127.0.0.1:3000

# ==========================================
# Stremio Addon Manifest
# ==========================================
ADDON_ID=org.stremio.tamilmv.addon
ADDON_NAME=Stremio MVShows Addon
ADDON_DESCRIPTION=An optimized Go port providing webseries and movie streams.
ADDON_VERSION=1.1.2
PLACEHOLDER_POSTER=https://upload.wikimedia.org/wikipedia/en/thumb/d/da/Aha_%28streaming_service.svg/250px-Aha_%28streaming_service.svg.png

# ==========================================
# Crawler & Forum URLs
# ==========================================
# Comma-separated forum section endpoints to parse for series and movies
SERIES_FORUM_URLS=
MOVIE_FORUM_URLS=
DUBBED_MOVIE_FORUM_URLS=

# ==========================================
# Full Sync Crawling Configuration
# ==========================================
# Used for the first database seeding run, or when FORCE_FULL_SCRAPE is true
SCRAPE_START_PAGE=1
SCRAPE_END_PAGE=35
FORUM_SORT_QUERY=&sortby=start_date&sortdirection=desc

# ==========================================
# Smart Incremental Crawling Configuration (New)
# ==========================================
# Used automatically once the database has more than 50 linked entries
SCRAPE_INCREMENTAL_END_PAGE=3
INCREMENTAL_SORT_QUERY=&sortby=last_post&sortdirection=desc

# Set to true if you want to bypass the dynamic 50-thread count threshold 
# and force the scheduler to run a deep 35-page scrape cycle.
FORCE_FULL_SCRAPE=false

# ==========================================
# Scraper Technical Settings
# ==========================================
SCRAPER_CONCURRENCY=5
SCRAPER_RETRY_COUNT=3
SCRAPER_TIMEOUT_SECS=30
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36

# Background scrape schedule (runs every 4 hours by default)
MAIN_WORKFLOW_CRON=0 */4 * * *

# Optional Netlify/Bypass Scraper Proxy URLs (comma-separated rotation list)
PROXY_URLS=

# ==========================================
# Metadata & Tracker Lists
# ==========================================
TMDB_API_KEY=your_tmdb_api_key_here
TRACKER_URL=https://ngosang.github.io/trackerslist/trackers_best.txt

# ==========================================
# Debrid Provider Integration
# ==========================================
# Options: "realdebrid", "torbox", or "none"
DEBRID_SERVICE=torbox

# API key for the selected service
REALDEBRID_API_KEY=your_realdebrid_api_key_here
TORBOX_API_KEY=your_torbox_api_key_here

# ==========================================
# Database Maintenance & Expiry Settings
# ==========================================
# Auto-vacuum SQLite space and clear temporary structures
DB_AUTO_VACUUM_ENABLED=true
DB_AUTO_VACUUM_CRON=0 3 * * *

# Automatic cleaning of unaccessed torrent cached entries (frees SQLite space)
CACHE_EXPIRY_ENABLED=true
CACHE_EXPIRY_DAYS=5
